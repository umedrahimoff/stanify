generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id         String   @id @default(cuid())
  telegramId String   @unique
  username   String?  @unique
  name       String?
  type       String   @default("channel") // "channel" | "group"
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  alerts     Alert[]
  keywords   ChannelKeyword[]
}

model ChannelKeyword {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([channelId, text])
}

model Alert {
  id          String   @id @default(cuid())
  channelName String
  channelId   String?
  channel     Channel? @relation(fields: [channelId], references: [id])
  content     String
  matchedWord String
  postLink    String?
  createdAt   DateTime @default(now())
}

model Session {
  id           String @id @default(cuid())
  sessionStr   String
  phoneNumber  String @unique
  isActive     Boolean @default(true)
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id        String   @id @default(cuid())
  username  String   @unique
  role      String   @default("moderator") // "admin" | "moderator"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model VerificationCode {
  id           String   @id @default(cuid())
  code         String
  targetUserId String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model DailyScanStats {
  id    String   @id @default(cuid())
  date  DateTime @unique
  count Int      @default(0)
}

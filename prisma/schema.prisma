generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id              String    @id @default(cuid())
  telegramId      String    @unique
  username        String?   @unique
  name            String?
  type            String    @default("channel") // "channel" | "group"
  isActive        Boolean   @default(false)
  saveAllPosts    Boolean   @default(false) // if true, save all posts to ChannelPost; else only keyword matches
  language        String?   // detected via OpenAI
  lastActivityAt   DateTime? // max(Alert.createdAt) for sorting
  createdAt       DateTime  @default(now())
  alerts      Alert[]
  keywords    ChannelKeyword[]
  channelPosts ChannelPost[]
  userChannels UserChannel[]
}

model ChannelPost {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  content   String
  messageId Int?
  postLink  String?
  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
}

model ChannelKeyword {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  text      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([channelId, text])
}

model GlobalKeyword {
  id         String   @id @default(cuid())
  text       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  recipients GlobalKeywordRecipient[]
}

model GlobalKeywordRecipient {
  id        String        @id @default(cuid())
  keywordId String
  keyword   GlobalKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  username  String
  createdAt DateTime      @default(now())

  @@unique([keywordId, username])
}

model Alert {
  id               String   @id @default(cuid())
  channelName      String
  channelId        String?
  channel          Channel? @relation(fields: [channelId], references: [id])
  content          String
  translatedContent String?  // cached DeepL translation for admin panel
  matchedWord      String
  postLink         String?
  source           String   @default("channel") // "channel" | "global"
  globalKeywordId  String?
  createdAt        DateTime @default(now())
}

model Session {
  id           String @id @default(cuid())
  sessionStr   String
  phoneNumber  String @unique
  isActive     Boolean @default(true)
  updatedAt    DateTime @updatedAt
}

model AppUser {
  id             String    @id @default(cuid())
  username       String    @unique
  role           String    @default("moderator") // "admin" | "moderator"
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  lastLoginAt    DateTime?
  lastActivityAt DateTime?
  userChannels   UserChannel[]
  userKeywords   UserKeyword[]
}

model UserChannel {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
}

model UserKeyword {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword   String
  createdAt DateTime @default(now())

  @@unique([userId, keyword])
}

model VerificationCode {
  id           String   @id @default(cuid())
  code         String
  targetUserId String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model DailyScanStats {
  id    String   @id @default(cuid())
  date  DateTime @unique
  count Int      @default(0)
}

model NotificationLog {
  id             String   @id @default(cuid())
  type           String   // "channel" | "global"
  keyword        String
  sourceChannel  String
  recipient      String
  success        Boolean
  errorMessage   String?
  alertId        String?
  contentPreview String?
  postLink       String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([recipient])
  @@index([type])
  @@index([keyword])
  @@index([sourceChannel])
}
